#: deps/js/components/src/visual-effect-control/index.js:25
msgid "Blur (px)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:26
msgid "Applies a blur effect to the image/video. A larger value will create more blur. Defaults to \"0\"."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:33
msgid "Brightness (%)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:34
msgid "Adjusts the brightness of the image/video. 0% will make the image completely black. 100% is default and represents the original image. Values over 100% will provide brighter results. Values under 100% will provide darker results."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:44
msgid "Contrast (%)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:47
msgid "Adjusts the contrast of the image/video. 0% will make the image completely gray. 100% is default, and represents the original image. Values over 100% increases the contrast. Values under 100% decreases the contrast."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:57
msgid "Grayscale (%)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:58
msgid "Converts the image to grayscale. 0% is default and represents the original image. 100% will make the image completely grayscale."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:68
msgid "Hue rotation (deg)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:69
msgid "Applies a hue rotation on the image. The value defines the number of degrees around the color circle the image samples will be adjusted. 0deg is default, and represents the original image. Maximum value is 360deg."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:79
msgid "Invert (%)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:80
msgid "Inverts the samples in the image. 0% is default and represents the original image. 100% will make the image completely inverted."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:90
msgid "Opacity (%)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:91
msgid "Sets the opacity level for the image. The opacity-level describes the transparency-level, where 0% is completely transparent. 100% is default and represents the original image (no transparency)."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:101
msgid "Saturate (%)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:104
msgid "Saturates the image. 0% will make the image completely un-saturated. 100% is default and represents the original image. Values over 100% provides super-saturated results."
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:114
msgid "Sepia (%)"
msgstr ""

#: deps/js/components/src/visual-effect-control/index.js:115
msgid "Converts the image to sepia. 0% is default and represents the original image. 100% will make the image completely sepia."
msgstr ""

